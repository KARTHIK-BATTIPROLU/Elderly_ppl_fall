rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /sensor_readings/{document=**} {
      allow read, write: if true;
    }
    match /predictions/{document=**} {
      allow read, write: if true;
    }
    match /alerts/{document=**} {
      allow read, write: if true;
    }
  }
}
